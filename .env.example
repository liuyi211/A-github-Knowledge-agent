# OMKA 环境变量配置
# 复制此文件为 .env 并填入实际值

# ===========================================
# GitHub API 配置
# ===========================================
GITHUB_TOKEN=your_github_token_here
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_API_VERSION=2022-11-28

# ===========================================
# LLM 模型配置
# ===========================================
# 支持: openai, qwen, ollama
LLM_PROVIDER=openai
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=30

# Ollama 本地模型配置（如果使用 ollama）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ===========================================
# 应用配置
# ===========================================
APP_NAME=OMKA
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true

# API 服务配置
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# ===========================================
# 数据库配置
# ===========================================
DATABASE_URL=sqlite:///data/db/app.sqlite
DATABASE_ECHO=false

# ===========================================
# 调度器配置
# ===========================================
# 每日抓取 Cron 表达式（默认每天早上 9:00）
SCHEDULER_DAILY_CRON=0 9 * * *
SCHEDULER_TIMEZONE=Asia/Shanghai

# ===========================================
# 数据采集配置
# ===========================================
# GitHub API 请求全局并发数
FETCH_CONCURRENCY=3
# 单次请求超时时间（秒）
FETCH_TIMEOUT=30
# 失败重试次数
FETCH_MAX_RETRIES=3
# 重试间隔基数（秒，指数退避）
FETCH_RETRY_BASE_DELAY=2

# Search API 限速（请求/分钟）
SEARCH_RATE_LIMIT=10

# 每日关键词搜索每个查询返回数量
SEARCH_RESULTS_PER_QUERY=5
# 每个仓库获取最新 Release 数量
RELEASES_PER_REPO=1

# GitHub 搜索限定符（附加到每个搜索查询后）
SEARCH_QUALIFIERS=in:name,description stars:>=5
# 搜索结果最低 star 数（低于此值的直接过滤）
SEARCH_MIN_STARS=10
# 每搜索源最大候选数（多策略召回时）
SEARCH_MAX_CANDIDATES_PER_QUERY=15
# 是否启用多策略召回（best_match + stars + updated）
SEARCH_EXPAND_QUERIES=false

# 搜索源头质量配置
SEARCH_QUALITY_MIN_SCORE=0.35
SEARCH_STALE_DAYS_THRESHOLD=365
SEARCH_DAILY_REQUEST_LIMIT=120
SEARCH_DAILY_ENRICH_LIMIT=40

# ===========================================
# 个性化排序配置
# ===========================================
# 打分权重
SCORE_WEIGHT_INTEREST=0.30
SCORE_WEIGHT_PROJECT=0.20
SCORE_WEIGHT_FRESHNESS=0.15
SCORE_WEIGHT_POPULARITY=0.10
SCORE_WEIGHT_SOURCE_QUALITY=0.25

# 新鲜度衰减天数（超过此天数分数降低）
FRESHNESS_DECAY_DAYS=7

# 每日简报 Top N 条目数
DIGEST_TOP_N=10

# 候选人最低分数阈值（低于此值的自动忽略）
CANDIDATE_SCORE_THRESHOLD=0.10

# ===========================================
# 知识库配置
# ===========================================
# 数据目录根路径
DATA_DIR=data
# 用户画像配置路径
PROFILES_DIR=data/profiles
# 原始数据保存路径
RAW_DATA_DIR=data/raw
# 每日简报输出路径
DIGESTS_DIR=data/digests
# 知识库保存路径
KNOWLEDGE_DIR=data/knowledge
# 多模态资产保存路径
ASSETS_DIR=data/assets

# ===========================================
# 推荐系统配置
# ===========================================
RECOMMENDATION_ENABLED=true
RECOMMENDATION_EXPLANATION_ENABLED=true
RECOMMENDATION_FEEDBACK_LEARNING_ENABLED=true

# ===========================================
# 推送策略配置
# ===========================================
PUSH_HIGH_SCORE_THRESHOLD=0.85
PUSH_MAX_PER_DAY=5
PUSH_QUIET_HOURS_START=22
PUSH_QUIET_HOURS_END=8

# ===========================================
# 记忆系统配置
# ===========================================
MEMORY_EXTRACTION_ENABLED=true
MEMORY_EXTRACTION_CONFIDENCE_THRESHOLD=0.8
MEMORY_MAX_ACTIVE_ITEMS=20

# ===========================================
# 多模态资产配置
# ===========================================
ASSET_MAX_FILE_SIZE_MB=10
ASSET_ALLOWED_IMAGE_TYPES=jpg,jpeg,png,webp
ASSET_ALLOWED_DOCUMENT_TYPES=pdf,md,txt

# ===========================================
# 飞书应用机器人配置
# ===========================================
FEISHU_ENABLED=false

# 飞书应用凭证
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# 事件订阅安全
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# API 配置
FEISHU_API_BASE_URL=https://open.feishu.cn/open-apis
FEISHU_REQUEST_TIMEOUT_SECONDS=10
FEISHU_MAX_RETRIES=3

# 消息目标
# receive_id_type 可选: chat_id, open_id, user_id, email
FEISHU_DEFAULT_RECEIVE_ID_TYPE=chat_id
FEISHU_DEFAULT_CHAT_ID=

# 机器人行为
FEISHU_COMMAND_PREFIX=/omka
FEISHU_REQUIRE_MENTION=true
FEISHU_GROUP_ALLOWLIST=
FEISHU_USER_ALLOWLIST=

# 简报推送
FEISHU_PUSH_DIGEST_ENABLED=true
FEISHU_PUSH_DIGEST_TOP_N=6

# 事件回调
FEISHU_EVENT_CALLBACK_PATH=/api/integrations/feishu/events
FEISHU_PUBLIC_CALLBACK_URL=

# Agent 对话（未来扩展）
FEISHU_AGENT_CONVERSATION_ENABLED=false
FEISHU_AGENT_SESSION_TTL_MINUTES=60
FEISHU_AGENT_MAX_MESSAGE_CHARS=4000
FEISHU_AUTO_BIND_DIRECT_CHAT=true
FEISHU_ADMIN_OPEN_IDS=
FEISHU_OPERATOR_OPEN_IDS=

# 飞书文档/表格默认文件夹（为空则创建在根目录）
FEISHU_DOC_FOLDER_TOKEN=
FEISHU_BASE_FOLDER_TOKEN=
FEISHU_SHEET_FOLDER_TOKEN=
# 默认日历 ID（为空则使用主日历）
FEISHU_DEFAULT_CALENDAR_ID=

# ===========================================
# Agent 配置
# ===========================================
OMKA_AGENT_CHAT_ENABLED=false
OMKA_AGENT_PROVIDER=
OMKA_AGENT_MODEL=
OMKA_AGENT_TEMPERATURE=0.2
OMKA_AGENT_TIMEOUT_SECONDS=60
OMKA_AGENT_MAX_RECENT_MESSAGES=6
OMKA_AGENT_MAX_DIGEST_ITEMS=5
OMKA_AGENT_MAX_KNOWLEDGE_ITEMS=5
OMKA_AGENT_MAX_CANDIDATE_ITEMS=5
OMKA_AGENT_MAX_CONTEXT_CHARS=12000

# [已废弃] 飞书 Webhook 配置（保留兼容性，默认关闭）
FEISHU_WEBHOOK_ENABLED=false
FEISHU_WEBHOOK_URL=
FEISHU_WEBHOOK_SECRET=

# ===========================================
# 日志配置
# ===========================================
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE_MAX_BYTES=10485760
LOG_FILE_BACKUP_COUNT=5
